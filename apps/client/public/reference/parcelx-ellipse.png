  <script>
    $('#Enquire-user').submit(
      ()=> {
        var user_name =$('#user_name').val()
        var user_number =$('#user_number').val()
        var shipment_value =$('#shipment_value').val()
        var useremail =$('#useremail').val()
        
        const url = `https://docs.google.com/forms/d/e/1FAIpQLSemDtdC5MV9kP7zSimbpt3WtkPrFtBgwdYvbP5tQZ77vff9JA/formResponse?&submit=Submit?usp=pp_url&entry.331191442=${user_name}&entry.783604537=${user_number}&entry.315175843=${useremail}&entry.116302553=${shipment_value}`;
        const myHeaders = new Headers();
        myHeaders.append("Cookie", "COMPASS=spreadsheet_forms=CjIACWuJV60cP_eaBJh0VAQgabzVd9VX6I9tdO4PCtT7Thp4WbDAACJ1E2lv_Ugw55VCfhDSx7q7Bho0AAlriVcBiVY-4srQ4SV7_U4gHRC08xF05-_OGRM9xK1IUp9bFUAqYIHDpgnXeJUxf2Iw==; S=spreadsheet_forms=4Xu93b61NHuPp0pdr98jD0Ei3BNu6lpdKD1TspSrSDQ; NID=520=ktw3XvGfAOBI0Emsn8OAJPIBCe2m34D8K5ed2z_LxpU51otSQadHFvLi4B-WmyfTnfnUT5mjtpEyKkf9KRHpaYw_DcxsOCc2_EOGs-7z_nn6jIP4jGJHLbYBKnoj2w1Rwmif6fdDBtrapcQzwf6lzJhzb4Ji9OU_UQq9ccbB0f_AXlK8yw");
        const requestOptions = {
          method: "post",
          headers: myHeaders,
        };
        function checkuseremail(input) {
          const re = /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
          if(re.test(input.value.trim())) {
              showSucces(input)
          }else {
              showError(input,'Email is not invalid');
          }
      }
        $.ajax({
          url: url,
          dataType: "jsonp",
          success: function (response) {
              console.log("Success:", response);
          },
          complete: function (data) {
            console.log("Request completed:", data); 
            setTimeout(() => {
              $(".Enquire-form").removeClass("show");
            }, 1000);

          },
          error: function(jqXHR, textStatus, errorThrown) {
            console.log('error');
          },
        });
      }
    )
    jQuery("#Enquire-user").on( 'submit', function(e){
      
      e.preventDefault();
      
      $.getScript('https://cdn.jsdelivr.net/npm/sweetalert2@11', function () {
          Swal.fire({
            title: 'Form Submitted!',
            text: 'Get Ready for the ParcelX!',
            icon: 'success',
            timer: 2000,
          });
        });
  });
  form.addEventListener('submit',function(e) {
    e.preventDefault();

    checkRequired([useremail]);
    checkEmaill(useremail);
});
  </script>
   
